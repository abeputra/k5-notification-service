<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pengumuman Proyek - Freelance Hub</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f2f5; min-height: 100vh; color: #333; }
    .navbar { background: linear-gradient(135deg, #1a237e, #283593); color: white; padding: 0 24px; height: 60px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
    .navbar h1 { font-size: 20px; font-weight: 700; }
    .navbar a { color: #c5cae9; text-decoration: none; font-size: 14px; }
    .navbar a:hover { color: white; }
    .container { max-width: 800px; margin: 0 auto; padding: 32px 24px; }
    .celebration { text-align: center; padding: 40px; background: linear-gradient(135deg, #1b5e20, #2e7d32); border-radius: 16px; color: white; margin-bottom: 28px; box-shadow: 0 4px 20px rgba(27,94,32,0.3); }
    .celebration .emoji { font-size: 64px; margin-bottom: 16px; display: block; }
    .celebration h1 { font-size: 28px; margin-bottom: 8px; }
    .celebration p { font-size: 16px; opacity: 0.9; }
    .card { background: white; border-radius: 12px; padding: 24px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .card h2 { font-size: 18px; color: #1a237e; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid #e8eaf6; display: flex; align-items: center; gap: 8px; }
    .info-row { display: flex; margin-bottom: 10px; }
    .info-label { font-weight: 600; color: #1a237e; min-width: 160px; font-size: 14px; }
    .info-value { color: #424242; font-size: 14px; flex: 1; }
    .skill-tag { display: inline-block; background: #e8eaf6; color: #3f51b5; padding: 4px 12px; border-radius: 20px; font-size: 12px; margin: 2px; font-weight: 500; }
    .member-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #f5f5f5; }
    .member-row:last-child { border-bottom: none; }
    .member-avatar { width: 36px; height: 36px; background: linear-gradient(135deg, #3f51b5, #7c4dff); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px; flex-shrink: 0; }
    .member-info .name { font-weight: 600; color: #1a237e; font-size: 14px; }
    .member-info .email { font-size: 12px; color: #666; }
    .status-badge { padding: 3px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .accepted { background: #e8f5e9; color: #2e7d32; }
    .btn { padding: 14px 28px; border: none; border-radius: 10px; cursor: pointer; font-size: 15px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s; text-decoration: none; }
    .btn-primary { background: #1a237e; color: white; }
    .btn-primary:hover { background: #0d1757; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(26,35,126,0.3); }
    .btn-success { background: #43a047; color: white; }
    .btn-success:hover { background: #388e3c; transform: translateY(-2px); }
    .generate-section { text-align: center; padding: 32px; background: linear-gradient(135deg, #e8eaf6, #f3f4fb); border-radius: 12px; margin-bottom: 20px; }
    .generate-section h3 { color: #1a237e; margin-bottom: 8px; font-size: 18px; }
    .generate-section p { color: #666; margin-bottom: 24px; font-size: 14px; }
    .alert { padding: 14px 18px; border-radius: 8px; margin-top: 16px; font-size: 14px; }
    .alert-success { background: #e8f5e9; color: #1b5e20; border-left: 4px solid #4caf50; }
    .alert-error { background: #ffebee; color: #b71c1c; border-left: 4px solid #f44336; }
    .alert-info { background: #e3f2fd; color: #0d47a1; border-left: 4px solid #2196f3; }
    .cache-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; margin-left: 8px; }
    .from-cache { background: #fff3e0; color: #e65100; }
    .from-db { background: #e8f5e9; color: #2e7d32; }
    .back-btn { display: inline-flex; align-items: center; gap: 6px; color: #3f51b5; text-decoration: none; font-size: 14px; margin-bottom: 20px; font-weight: 500; }
    .back-btn:hover { color: #1a237e; }
    .loading { text-align: center; padding: 60px; }
    .spinner { display: inline-block; width: 40px; height: 40px; border: 4px solid #e8eaf6; border-top-color: #3f51b5; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <nav class="navbar">
    <h1>🚀 Freelance Hub</h1>
    <a href="/">← Kembali ke Dashboard</a>
  </nav>

  <div class="container">
    <a href="/" class="back-btn">← Dashboard</a>

    <div id="loading" class="loading">
      <div class="spinner"></div>
      <p style="margin-top:16px;color:#666;">Memuat data pengumuman...</p>
    </div>

    <div id="content" style="display:none;">
      <!-- Status Header: berubah sesuai status proyek -->
      <div id="header-waiting" class="celebration" style="background: linear-gradient(135deg, #37474f, #455a64);">
        <span class="emoji">⏳</span>
        <h1>Pengumuman Sedang Disiapkan</h1>
        <p id="waiting-text">Proyek ini belum memasuki tahap seleksi akhir. Pantau terus halaman ini.</p>
      </div>
      <div id="header-accepted" class="celebration" style="display:none;">
        <span class="emoji">🎉</span>
        <h1>Selamat! Kamu Diterima!</h1>
        <p id="congrats-text">Kamu telah diterima sebagai anggota tim proyek.</p>
      </div>

      <!-- Info Proyek -->
      <div class="card">
        <h2>📌 Informasi Proyek <span id="cache-badge"></span></h2>
        <div id="project-info"></div>
      </div>

      <!-- Anggota Tim -->
      <div class="card" id="members-card">
        <h2>👥 Anggota Tim</h2>
        <div id="members-list"></div>
      </div>

      <!-- Generate Kontrak: hanya tampil kalau status in_progress/completed -->
      <div id="generate-section" class="generate-section" style="display:none;">
        <h3>📄 Kontrak Kerja Digital</h3>
        <p>Unduh kontrak kerja proyek yang telah disiapkan sistem secara otomatis untuk kamu.</p>
        <button class="btn btn-primary" onclick="generatePDF()">
          📥 Generate & Unduh Kontrak PDF
        </button>
        <div id="pdf-alert"></div>
      </div>
      <!-- Pesan kalau belum accepted -->
      <div id="pending-section" style="text-align:center; padding:28px; background:#f5f5f5; border-radius:12px; margin-bottom:20px;">
        <div style="font-size:40px; margin-bottom:12px;">📋</div>
        <h3 style="color:#455a64; margin-bottom:8px;">Kontrak Belum Tersedia</h3>
        <p style="color:#666; font-size:14px;">Kontrak hanya bisa diunduh setelah panitia melakukan konfirmasi penerimaan.</p>
      </div>
    </div>

    <div id="not-found" style="display:none; text-align:center; padding:60px;">
      <div style="font-size:64px;">😕</div>
      <h2 style="color:#1a237e;margin:16px 0 8px;">Proyek Tidak Ditemukan</h2>
      <p style="color:#666;">Proyek ini tidak ada atau sudah dihapus.</p>
      <a href="/" class="btn btn-primary" style="margin-top:20px;display:inline-flex;">← Kembali</a>
    </div>
  </div>

  <script>
    const projectId = '<%= projectId %>';
    let projectData = null;

    async function loadAnnouncement() {
      try {
        const res = await fetch(`/api/announcements/project/${projectId}`);
        const result = await res.json();

        document.getElementById('loading').style.display = 'none';

        if (!result.success) {
          document.getElementById('not-found').style.display = 'block';
          return;
        }

        document.getElementById('content').style.display = 'block';
        projectData = result.data;
        const { project, members } = result.data;
        const fromCache = result.from_cache;

        // Cache badge
        const badgeEl = document.getElementById('cache-badge');
        badgeEl.innerHTML = `<span class="cache-badge ${fromCache ? 'from-cache' : 'from-db'}">
          ${fromCache ? '⚡ Redis Cache' : '🗄️ Database'}
        </span>`;

        // Tampilkan header sesuai status proyek
        const isAccepted = project.status === 'in_progress' || project.status === 'completed';
        document.getElementById('header-waiting').style.display = isAccepted ? 'none' : 'block';
        document.getElementById('header-accepted').style.display = isAccepted ? 'block' : 'none';
        document.getElementById('generate-section').style.display = isAccepted ? 'block' : 'none';
        document.getElementById('pending-section').style.display = isAccepted ? 'none' : 'block';

        if (isAccepted) {
          document.getElementById('congrats-text').textContent =
            `Kamu telah diterima sebagai anggota tim proyek "${project.title}"`;
        } else {
          document.getElementById('waiting-text').textContent =
            `Proyek "${project.title}" belum memasuki tahap seleksi akhir.`;
        }

        // Project info
        document.getElementById('project-info').innerHTML = `
          <div class="info-row"><span class="info-label">Nama Proyek</span><span class="info-value"><strong>${project.title}</strong></span></div>
          <div class="info-row"><span class="info-label">Klien</span><span class="info-value">${project.client_name || '-'}</span></div>
          <div class="info-row"><span class="info-label">Budget</span><span class="info-value">${project.budget || '-'}</span></div>
          <div class="info-row"><span class="info-label">Status</span><span class="info-value"><span class="status-badge accepted">${project.status}</span></span></div>
          <div class="info-row"><span class="info-label">Tanggal Dibuat</span><span class="info-value">${new Date(project.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span></div>
          <div class="info-row"><span class="info-label">Skill Dibutuhkan</span><span class="info-value">${(project.required_skills || []).map(s => `<span class="skill-tag">${s}</span>`).join('')}</span></div>
          ${project.description ? `<div class="info-row"><span class="info-label">Deskripsi</span><span class="info-value">${project.description}</span></div>` : ''}
        `;

        // Members - hanya tampilkan kalau sudah ada yang diterima
        const allMembers = members;
        if (allMembers.length === 0) {
          document.getElementById('members-list').innerHTML =
            '<p style="color:#999;text-align:center;padding:20px;">Belum ada anggota yang diterima.</p>';
        } else {
        document.getElementById('members-list').innerHTML = allMembers.map(m => `
          <div class="member-row">
            <div class="member-avatar">${(m.name || 'U').charAt(0).toUpperCase()}</div>
            <div class="member-info">
              <div class="name">${m.name || '-'}</div>
              <div class="email">${m.email || '-'}</div>
            </div>
            <span class="status-badge accepted">✅ Diterima</span>
          </div>
        `).join('');
        }

      } catch (err) {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('not-found').style.display = 'block';
      }
    }

    async function generatePDF() {
      const alertDiv = document.getElementById('pdf-alert');
      alertDiv.innerHTML = '<div class="alert alert-info">⏳ Generating PDF kontrak... harap tunggu.</div>';

      try {
        const res = await fetch('/api/pdf/generate-contract', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ project_id: projectId })
        });

        if (res.headers.get('content-type')?.includes('application/pdf')) {
          // Download langsung
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `kontrak_proyek_${projectId}.pdf`;
          a.click();
          alertDiv.innerHTML = '<div class="alert alert-success">✅ PDF kontrak berhasil diunduh!</div>';
        } else {
          const result = await res.json();
          if (result.success) {
            // PDF download tersedia via /api/pdf/contracts else {
              alertDiv.innerHTML = '<div class="alert alert-success">✅ PDF berhasil digenerate!</div>';
            }
          } else {
            alertDiv.innerHTML = `<div class="alert alert-error">❌ ${result.error}</div>`;
          }
        }
      } catch (err) {
        alertDiv.innerHTML = `<div class="alert alert-error">❌ Error: ${err.message}</div>`;
      }
    }

    loadAnnouncement();
  </script>
</body>
</html>
