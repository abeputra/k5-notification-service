# ============================================
# KELOMPOK 5 - FREELANCE HUB NOTIFY SERVICE
# Salin file ini: cp .env.example .env
# Lalu isi nilai yang kosong
# ============================================

PORT=8080
NODE_ENV=development
APP_URL=http://localhost:8085

# ── PostgreSQL ───────────────────────────────
# (dibuat otomatis oleh docker compose)
DB_HOST=db-notify
DB_PORT=5432
DB_NAME=notify_db
DB_USER=notify_user
DB_PASS=notify_pass123

# ── Redis ────────────────────────────────────
# Saat standalone test: redis
# Saat join nexus CPU kampus: redis-main
REDIS_HOST=redis-main
REDIS_PORT=6379
REDIS_TTL=3600

# ── Email Brevo SMTP ─────────────────────────
# Dari: app.brevo.com → SMTP & API → SMTP → Generate Key
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_login@smtp-brevo.com
MAIL_PASS=xsmtpsib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM="Freelance Hub Notify <apl.kelompoklima@gmail.com>"

# ── JWT (harus sama dengan Kelompok 1) ───────
JWT_SECRET=shared-jwt-secret

# ── RabbitMQ ─────────────────────────────────
# Saat join nexus CPU kampus:
RABBITMQ_URL=amqp://guest:guest@rabbit-main:5672
RABBITMQ_QUEUE=kelompok5.notification.queue
